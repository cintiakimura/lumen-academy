# Lumen Academy — Vercel + Supabase
# Copy to .env.local (or .env) and fill. Do not commit .env or .env.local.
# In Vercel: Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: API base when app and API are different origins (e.g. VITE_API_URL= for same origin)
# VITE_API_URL=

# Server (Vercel): add in Dashboard → Environment Variables
# XAI_API_KEY=your-xai-api-key
